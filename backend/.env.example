NODE_ENV=development
PORT=3000
DATABASE_URL="file:./prisma/backend.db"
FRONTEND_URL=http://localhost:5173
OIDC_ISSUER=http://localhost:3000
OAUTH_CALLBACK_BASE_URL=http://localhost:3000
JWT_ACCESS_TOKEN_EXPIRES_IN=3600
JWT_REFRESH_TOKEN_EXPIRES_IN=604800
JWT_KEY_ID=sso-dev-key
BACKUP_DIR=backups
AUTO_BACKUP_ENABLED=false
AUTO_BACKUP_INTERVAL_HOURS=24
AUTO_BACKUP_RETENTION_COUNT=7
AUTO_BACKUP_COMPRESS=true
ENABLE_DEBUG_EMAIL_CODE=true

# Optional seed values for local development
ADMIN_EMAIL=admin@sso.local
ADMIN_PASSWORD=123456
DEMO_CLIENT_ID=demo-web-client
DEMO_CLIENT_SECRET=demo-secret-123456
DEMO_CLIENT_REDIRECT_URIS=http://localhost:5173/oauth/callback,http://localhost:5173/test
