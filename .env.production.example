# Copy to .env on the server and replace the domain.
FRONTEND_URL=https://sso.example.com
OIDC_ISSUER=https://sso.example.com
OAUTH_CALLBACK_BASE_URL=https://sso.example.com

# Optional build acceleration for mainland China servers.
NODE_IMAGE=docker.m.daocloud.io/library/node:22-bookworm-slim
NPM_REGISTRY=https://registry.npmmirror.com
PRISMA_ENGINES_MIRROR=https://npmmirror.com/mirrors/prisma
DEBIAN_MIRROR=http://mirrors.aliyun.com/debian
DEBIAN_SECURITY_MIRROR=http://mirrors.aliyun.com/debian-security

# Optional tuning
JWT_ACCESS_TOKEN_EXPIRES_IN=3600
JWT_REFRESH_TOKEN_EXPIRES_IN=604800
JWT_KEY_ID=sso-prod-key
SECRET_ENCRYPTION_KEY=replace-with-a-random-32-byte-hex-string
ENABLE_DEBUG_EMAIL_CODE=false
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_HOURS=24
AUTO_BACKUP_RETENTION_COUNT=14
AUTO_BACKUP_COMPRESS=true
